<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <title>DeSina Redirecting...</title>
    <script type="text/javascript">
      // كود جيمي العبقري لتحويل الحروف
      var path = window.location.pathname.toLowerCase();
      if (path === '/desina' || path === '/desina/') {
        window.location.href = 'https://desinacom-web.github.io/DeSina/index.html';
      } else {
        window.location.href = 'index.html';
      }
    </script>
  </head>
  <body>
  </body>
</html>
